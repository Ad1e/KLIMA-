# Preferred: full connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/klima

# Or use individual PG vars
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=klima

PORT=4000

# Default seeded admin for /auth/login during create-db
ADMIN_EMAIL=admin@klima.local
ADMIN_PASSWORD=admin123
