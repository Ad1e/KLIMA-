# Copy this file to .env.local and replace values for real-time weather data.
# Vite exposes only variables prefixed with VITE_.
VITE_WEATHER_API_KEY=your_weather_api_key_here
VITE_WEATHER_API_URL=https://api.openweathermap.org/data/2.5/weather
VITE_OPEN_METEO_FORECAST_API_URL=https://api.open-meteo.com/v1/forecast
VITE_OPEN_METEO_TIMEZONE=Asia/Manila
VITE_GDACS_TYHOON_EVENTS_API_URL=https://www.gdacs.org/gdacsapi/api/events/geteventlist/SEARCH?eventtype=TC
VITE_PAGASA_CYCLONE_DAT_URL=https://pubfiles.pagasa.dost.gov.ph/tamss/weather/cyclone.dat
